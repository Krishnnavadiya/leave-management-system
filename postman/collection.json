{
  "info": {
    "name": "Employee Leave Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Manager",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employee1@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{YOUR_REFRESH_TOKEN}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/refresh-token",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "refresh-token"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{YOUR_REFRESH_TOKEN}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/employees/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "employees", "profile"]
            }
          }
        },
        {
          "name": "List All Employees (Manager Only)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/employees?search=Bob&department=Marketing",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "employees"],
              "query": [
                { "key": "search", "value": "Bob" },
                { "key": "department", "value": "Marketing" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Leaves",
      "item": [
        {
          "name": "Apply Leave",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveType\": \"ANNUAL\",\n  \"startDate\": \"2026-07-20T00:00:00.000Z\",\n  \"endDate\": \"2026-07-25T00:00:00.000Z\",\n  \"reason\": \"Family summer vacation\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/leaves",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "leaves"]
            }
          }
        },
        {
          "name": "Get My Leave History",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/leaves?status=PENDING",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "leaves"],
              "query": [
                { "key": "status", "value": "PENDING" }
              ]
            }
          }
        },
        {
          "name": "Update Pending Leave",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveType\": \"ANNUAL\",\n  \"startDate\": \"2026-07-20T00:00:00.000Z\",\n  \"endDate\": \"2026-07-27T00:00:00.000Z\",\n  \"reason\": \"Family vacation extended\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/leaves/{{LEAVE_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "leaves", "{{LEAVE_ID}}"]
            }
          }
        },
        {
          "name": "Cancel Approved/Pending Leave",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/leaves/{{LEAVE_ID}}/cancel",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "leaves", "{{LEAVE_ID}}", "cancel"]
            }
          }
        },
        {
          "name": "Delete Pending Leave",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/leaves/{{LEAVE_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "leaves", "{{LEAVE_ID}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Manager Actions",
      "item": [
        {
          "name": "List Pending Leaves",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/manager/pending-leaves",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager", "pending-leaves"]
            }
          }
        },
        {
          "name": "Approve Leave",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment\": \"Looks good, please make sure documentation is updated before you leave.\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/manager/leaves/{{LEAVE_ID}}/approve",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager", "leaves", "{{LEAVE_ID}}", "approve"]
            }
          }
        },
        {
          "name": "Reject Leave",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment\": \"Sorry, we have a critical deployment scheduled during these dates.\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/manager/leaves/{{LEAVE_ID}}/reject",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager", "leaves", "{{LEAVE_ID}}", "reject"]
            }
          }
        }
      ]
    }
  ]
}
