# Application Config
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Connection (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leave_management?schema=public

# JWT Security Secrets
JWT_ACCESS_SECRET=your_jwt_access_token_secret_here_must_be_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_here_must_be_long_and_secure

# Token Expirations
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
